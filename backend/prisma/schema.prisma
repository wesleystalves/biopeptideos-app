// Prisma schema para Peptídeos Health
// Mapeado EXATAMENTE para o schema PostgreSQL existente

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Peptide {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(200)
  category       String?  @db.VarChar(100)
  description    String?
  mechanism      String?
  benefits       String[]
  variants       String[]
  stability      String?  @db.VarChar(100)
  halfLife       String?  @map("half_life") @db.VarChar(100)
  reconstitution String?
  storage        String?  @db.VarChar(200)
  isFree         Boolean  @default(false) @map("is_free")
  imagePath      String?  @map("image_path") @db.VarChar(300)
  slug           String?  @unique @db.VarChar(200)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("peptides")
}

model Profile {
  id          String   @id @default(uuid())
  email       String   @unique @db.VarChar(255)
  displayName String?  @map("display_name") @db.VarChar(200)
  name        String?  @db.VarChar(200)
  phone       String?  @db.VarChar(50)
  password    String?
  plan        String   @default("free") @db.VarChar(50)
  isAdmin     Boolean  @default(false) @map("is_admin")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]
  roles         UserRole[]

  @@map("profiles")
}

model Subscription {
  id              Int       @id @default(autoincrement())
  userId          String?   @map("user_id")
  plan            String?   @default("free") @db.VarChar(50)
  status          String?   @default("active") @db.VarChar(50)
  activatedAt     DateTime? @default(now()) @map("activated_at")
  expiresAt       DateTime? @map("expires_at")
  paymentProvider String?   @map("payment_provider") @db.VarChar(50)
  externalId      String?   @map("external_id") @db.VarChar(200)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  profile Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    String?  @map("user_id")
  role      String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_roles")
}

model Protocol {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  peptides    String[]
  duration    String?
  objective   String?
  isFree      Boolean  @default(false) @map("is_free")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("protocols")
}

model MarketingLead {
  id        String   @id @default(uuid())
  email     String   @unique @db.VarChar(255)
  source    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("marketing_leads")
}
