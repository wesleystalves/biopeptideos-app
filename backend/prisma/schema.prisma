// This is your Prisma schema file
// BioPeptidios — Full Platform Schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH ====================

model Profile {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String?
  name             String?
  displayName      String?  @map("display_name")
  avatarUrl        String?  @map("avatar_url")
  phone            String?
  countryCode      String?  @map("country_code") @default("BR")
  isAdmin          Boolean  @default(false) @map("is_admin")
  // plan: "free" | "basic" | "premium"
  // free    = sem compra
  // basic   = ebook (R$9,90)
  // premium = ebook + IA (R$29,90)
  plan             String   @default("free")
  autoLoginToken   String?  @unique @map("auto_login_token")
  autoLoginExpires DateTime? @map("auto_login_expires")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  subscriptions    Subscription[]
  orders           Order[]
  ebookPurchases   EbookPurchase[]

  @@map("profiles")
}

// Rastreia compras do ebook para histórico e idempotência
model EbookPurchase {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  plan       String   // "basic" | "premium"
  amount     Float
  gateway    String   @default("asaas")
  gatewayId  String   @unique @map("gateway_id") // garante idempotência
  status     String   @default("paid")
  createdAt  DateTime @default(now()) @map("created_at")

  profile    Profile  @relation(fields: [userId], references: [id])

  @@map("ebook_purchases")
}

// ==================== CUPONS ====================

model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique // Ex: LAUNCH50
  description   String?   // "Lançamento — 50% off"

  // Tipo de desconto
  discountType  String    @default("percent") // "percent" | "fixed"
  discountValue Float     // 50 (%) ou 5.00 (R$)

  // Limites
  maxUses       Int?      @map("max_uses")       // null = ilimitado
  usedCount     Int       @default(0) @map("used_count")
  minAmount     Float?    @map("min_amount")      // valor mínimo para aplicar

  // Escopo — quais planos aceitam (json array: ["basic","premium"] ou null = todos)
  allowedPlans  String?   @map("allowed_plans")

  // Validade
  startsAt      DateTime? @map("starts_at")
  expiresAt     DateTime? @map("expires_at")

  // Estado
  isActive      Boolean   @default(true) @map("is_active")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("coupons")
}


model Subscription {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  plan      String    @default("free")
  status    String    @default("inactive")
  gateway   String?
  gatewayId String?   @map("gateway_id")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  profile   Profile   @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

// ==================== CATALOG ====================

model Peptide {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  category    String?
  imageUrl    String?  @map("image_url")
  isPro       Boolean  @default(false) @map("is_pro")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("peptides")
}

model Product {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  description      String?
  longDescription  String?  @map("long_description")
  price            Float
  currency         String   @default("USD")
  category         String
  imageUrl         String?  @map("image_url")
  images           String[] @default([])
  featured         Boolean  @default(false)
  isActive         Boolean  @default(true) @map("is_active")
  stockQty         Int      @default(999) @map("stock_qty")
  allowedCountries String[] @default([]) @map("allowed_countries")
  tags             Json     @default("[]")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  orders           Order[]

  @@map("products")
}

// ==================== ECOMMERCE ====================

model Order {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  productId        String   @map("product_id")
  amount           Float
  currency         String
  status           String   @default("pending") // pending | paid | shipped | delivered | cancelled | refunded
  gateway          String?
  gatewayPaymentId String?  @map("gateway_payment_id")
  shippingAddress  Json?    @map("shipping_address")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  profile          Profile  @relation(fields: [userId], references: [id])
  product          Product  @relation(fields: [productId], references: [id])

  @@map("orders")
}

// ==================== CRM ====================

model Lead {
  id          String   @id @default(uuid())
  name        String?
  email       String?
  phone       String?
  channel     String   // whatsapp | telegram | email | chat
  status      String   @default("new") // new | contacted | qualified | proposal | negotiation | won | lost
  score       Int      @default(0)
  countryCode String?  @map("country_code")
  source      String?
  tags        Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  conversations Conversation[]

  @@unique([phone, channel], map: "phone_channel")
  @@map("leads")
}

model Conversation {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  channel   String   // whatsapp | telegram | email | chat
  role      String   // user | assistant | system
  content   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  lead      Lead     @relation(fields: [leadId], references: [id])

  @@map("conversations")
}

// ==================== COMPLIANCE ====================

model ComplianceRule {
  id                   String   @id @default(uuid())
  countryCode          String   @map("country_code")
  productCategory      String   @map("product_category")
  status               String   // allowed | restricted | blocked
  requiresPrescription Boolean  @default(false) @map("requires_prescription")
  notes                String?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([countryCode, productCategory], map: "countryCode_productCategory")
  @@map("compliance_rules")
}

// ==================== SETTINGS ====================

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ==================== GUIDES & PROTOCOLS (legado) ====================

model Guide {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  content   String?
  isPro     Boolean  @default(false) @map("is_pro")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("guides")
}

model Protocol {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  isPro       Boolean  @default(false) @map("is_pro")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("protocols")
}
